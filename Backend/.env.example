# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/decorabake

# Server Port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5174

# JWT Secret - Use a strong random string in production
JWT_SECRET=your-strong-random-secret-key-here

# Node Environment (development | production)
NODE_ENV=development

# ImageKit — Cloud Image Storage (get from imagekit.io → Developer Options → API Keys)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Gemini API Key (optional - for chatbot)
GEMINI_API_KEY=

# Qwen API Key (optional - for chatbot fallback)
QWEN_API_KEY=

# OpenRouter API Key (optional - for chatbot fallback)
OPENROUTER_API_KEY=

# Stripe Keys (optional - for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
